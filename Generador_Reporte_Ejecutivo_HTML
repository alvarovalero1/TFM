items_validos = [
    x for x in _items
    if x is not None and isinstance(x, dict) and "json" in x and x["json"]
]

items_priorizados = sorted(
    items_validos,
    key=lambda x: x["json"].get("ipc_score", 0),
    reverse=True
)

# ─── CONTADORES KPI ───────────────────────────────────────────────────────────
total_criticas        = 0
total_altas           = 0
total_escaladas       = 0
total_no_resueltas    = 0
total_en_progreso     = 0
total_resueltas       = 0
suma_riesgo_economico = 0.0
filas_html            = ""

for item in items_priorizados:
    row = item["json"]

    id_v       = row.get("id_vuln",               "N/A")
    activo     = row.get("nombre_activo",          "Desconocido")
    cvss       = float(row.get("cvss_base",        0))
    score      = float(row.get("ipc_score",        0))
    riesgo_eur = float(row.get("riesgo_financiero_eur", 0))
    prioridad  = row.get("prioridad_soar",         "BAJA")
    sla        = row.get("sla_remediacion",        "Pendiente")
    notificar  = row.get("notificar_ciso",         False)
    amenaza    = row.get("tiene_exploit",          "NO")
    expo       = row.get("exposicion",             "INTERNA")
    cumple     = row.get("cumplimiento",           "NO")
    weapon     = row.get("weaponization",          "N/A")
    estado     = row.get("estado",                 "NO_RESUELTA")
    escalada   = row.get("escalada",               False)
    motivo     = row.get("motivo_escalado",        "")

    suma_riesgo_economico += riesgo_eur

    # Contadores de prioridad
    if prioridad in ("CRITICA", "CRITICA_ESCALADA"):
        total_criticas += 1
    elif prioridad == "ALTA":
        total_altas += 1
    if escalada:
        total_escaladas += 1

    # Contadores de estado
    if estado == "RESUELTA":
        total_resueltas += 1
    elif estado == "EN_PROGRESO":
        total_en_progreso += 1
    else:
        total_no_resueltas += 1

    # ── Colores por prioridad ─────────────────────────────────────────────────
    if prioridad == "CRITICA_ESCALADA":
        color = "#c0392b"
    elif prioridad == "CRITICA":
        color = "#e74c3c"
    elif prioridad == "ALTA":
        color = "#e67e22"
    elif prioridad == "MEDIA":
        color = "#f39c12"
    else:
        color = "#7f8c8d"

    # ── Colores por estado ────────────────────────────────────────────────────
    if estado == "RESUELTA":
        color_estado = "#27ae60"
        icono_estado = "\u2705"
    elif estado == "EN_PROGRESO":
        color_estado = "#e67e22"
        icono_estado = "\u23f3"
    else:
        color_estado = "#e74c3c"
        icono_estado = "\u274c"

    # ── Color weaponization ───────────────────────────────────────────────────
