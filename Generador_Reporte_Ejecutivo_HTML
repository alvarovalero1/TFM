        color_weapon = "#e74c3c"
    elif weapon == "MEDIA":
        color_weapon = "#e67e22"
    else:
        color_weapon = "#7f8c8d"

    alerta = "\U0001f514 " if notificar else ""

    # ── Banner de escalado ────────────────────────────────────────────────────
    fila_escalado = ""
    if escalada and motivo:
        fila_escalado = f"""
    <tr style="background:#fdf2f2;">
        <td colspan="12" style="padding:6px 14px; font-size:11px;
            color:#c0392b; font-style:italic; border-bottom:1px solid #f5c6c6;">
            \u26a0\ufe0f {motivo}
        </td>
    </tr>"""

    filas_html += f"""
