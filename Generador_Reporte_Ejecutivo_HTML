        <td style="text-align:center; font-size:11px; color:#555;">{amenaza}</td>
        <td style="text-align:center; font-size:11px; color:#555;">{expo}</td>
        <td style="text-align:center; font-size:11px; color:#555;">{cumple}</td>
        <td style="text-align:center; font-size:11px; color:{color_weapon}; font-weight:bold;">{weapon}</td>
        <td style="text-align:center; font-weight:bold; color:{color};">{score:.2f}</td>
        <td style="text-align:right; font-weight:bold; color:#27ae60;">{riesgo_eur:,.2f} \u20ac</td>
        <td style="text-align:center;">
            <span style="background:{color}; color:white; padding:4px 10px;
                  border-radius:15px; font-size:11px; font-weight:bold;">{prioridad}</span>
        </td>
        <td style="text-align:center;">
            <span style="background:{color_estado}; color:white; padding:4px 10px;
                  border-radius:15px; font-size:11px; font-weight:bold;">
                {icono_estado} {estado}
            </span>
        </td>
        <td style="text-align:center; color:#555; font-size:12px;">{sla}</td>
    </tr>"""

# ─── BARRA DE PROGRESO ────────────────────────────────────────────────────────
